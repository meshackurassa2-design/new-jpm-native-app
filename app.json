{
  "expo": {
    "name": "JPM",
    "slug": "jpm-socialmarket",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "jpm",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jpm.app"
    },
    "android": {
      "package": "com.jpm.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8166782428171770~2422181294",
          "iosAppId": "ca-app-pub-8166782428171770~2422181294"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f61baa2-e792-4ed0-a9fb-fe3de10c0445"
      }
    }
  }
}
